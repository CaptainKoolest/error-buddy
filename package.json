{
  "name": "error-buddy",
  "displayName": "error~buddy",
  "description": "Explains programming errors and suggests fixes.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  
  "main": "./extension.js",
  "contributes": {
	"commands": [
		{
			"command": "error-buddy.explainError",
			"title": "Explain Error with Error Buddy"
		}
	],
	"keybindings": [
		{
			"command": "error-buddy.explainError",
			"key": "ctrl+alt+e",
			"when": "editorHasSelection || terminalFocus"
		}
	]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
